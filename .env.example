# ─── PIX Sandbox (Stark Bank) ─────────────────────────────────────────────────
# Solicitar credenciais à Squad Billing (referência: ARC-1245).
# Sem essas variáveis os testes PAY-P4b ficam em modo manual (page.pause).
#
# Passos para rodar o fluxo PIX completo (automático):
#   1. npm run tool:pix-capture        → gera BR Code pendente
#   2. npm run tool:pix-pay            → paga via Stark API
#   3. npm run test:pix:emission       → aguarda webhook + finaliza
#
STARK_PROJECT_ID=
STARK_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n<cole aqui>\n-----END EC PRIVATE KEY-----"
STARK_TAX_ID=                          # CPF/CNPJ da conta Stark sandbox (11 ou 14 dígitos)

# Liga modo automático (requer STARK_* preenchido):
PIX_SANDBOX_EMISSION=                  # defina como 1 para ativar PAY-P4b
PIX_SANDBOX_AUTO_PAY=                  # defina como 1 para pagar automaticamente via Stark
PIX_SANDBOX_MANUAL_PAUSE=              # defina como 0 para desligar page.pause no modo manual
TIMEOUT=60000
