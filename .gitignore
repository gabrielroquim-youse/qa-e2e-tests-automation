# ── Dependências ─────────────────────────────────────────────────────────────
node_modules/

# ── Ambiente (nunca versionar secrets) ───────────────────────────────────────
.env
.env.*
!.env.example

# ── SO / IDE ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*.orig

# ── Build TypeScript ─────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo
*.js.map

# ── Playwright — artefatos de execução ───────────────────────────────────────
playwright-report/
test-results/
blob-report/
all-blob-reports/
storage/

# ── Allure — artefatos de execução ───────────────────────────────────────────
allure-results/
allure-report/

# ── Relatórios de execução (gerados automaticamente — não versionar) ─────────
# Raiz
/reports/
# Exceção: histórico do Allure para rastreabilidade de tendências (5+ dias)
!reports/allure-history/
!reports/allure-history/**

# docs/reports: JSONs de timing, capturas de rede e histórico de runs
docs/reports/*.json
docs/reports/*.md
docs/reports/history/
docs/reports/videos/*.webm
docs/reports/videos/*.mp4
# Exceção: documentação estática do diretório
!docs/reports/README.md

# ── Logs e artefatos temporários ─────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Mídia gerada em execução (screenshots, vídeos, traces) ───────────────────
*.png
*.jpg
*.jpeg
*.mp4
*.webm
*.har
*.trace
*.zip

# ── Cache e temporários ───────────────────────────────────────────────────────
.cache/
.tmp/
tmp/
temp/
coverage/
.nyc_output/

# ── Agentes Playwright (gerados pelo Copilot — não versionar) ────────────────
.github/agents/
.github/chatmodes/
