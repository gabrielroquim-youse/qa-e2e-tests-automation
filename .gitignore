# ── Dependências ─────────────────────────────────────────────────────────────
node_modules/

# ── Ambiente (nunca versionar secrets) ───────────────────────────────────────
.env
.env.*

# ── SO / IDE ─────────────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# ── Build TypeScript ─────────────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ── Playwright ───────────────────────────────────────────────────────────────
playwright-report/
test-results/
blob-report/
all-blob-reports/
storage/

# ── Allure ───────────────────────────────────────────────────────────────────
allure-results/
allure-report/

# ── Artefatos locais de execução (scratch na raiz — saídas finais em docs/reports/)
/reports/

# Logs na raiz (Tee-Object, redirects manuais, playwright install)
/*.log

# Screenshots/debug na raiz (geradas por scripts de captura PIX, axe, etc.)
/*.png
/*.jpg
/*.jpeg
/*.mp4
/*.webm
/*.har
/*.trace
/*.zip

# Vídeos de execução PIX (artefatos pesados — manter apenas o "latest" se necessário)
docs/reports/videos/*.webm
!docs/reports/videos/.gitkeep

# Captura PIX local (BR Code + protocolo de sessão)
docs/reports/pix-brcode-capture.json

# ── Agentes Playwright (gerados pelo Copilot — não versionar) ───────────────
.github/agents/
.github/chatmodes/
