{
  "name": "playwright-e2e-tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/spec/e2e/journeys tests/spec/e2e/ux --grep @smoke --project=chromium",
    "test:journey": "playwright test tests/spec/e2e/journeys --grep @journey --project=chromium",
    "test:ux": "playwright test tests/spec/e2e/ux --grep @ux --project=chromium",
    "test:regression": "playwright test tests/spec/e2e/regression --grep @regression --project=chromium",
    "test:api": "playwright test tests/spec/api --project=chromium",
    "test:api:quotation": "playwright test tests/spec/api/quotation --grep @pricing --project=chromium",
    "test:a11y": "playwright test -c playwright.a11y.config.ts --grep @a11y --reporter=list",
    "test:a11y:sandbox": "playwright test -c playwright.a11y.config.ts --grep @a11y --reporter=list",
    "test:a11y:mobile": "playwright test -c playwright.a11y.config.ts --grep @a11y --project=mobile-chrome --project=mobile-ios --reporter=list",
    "test:a11y:tablet": "playwright test -c playwright.a11y.config.ts --grep @a11y --project=tablet --reporter=list",
    "test:keyboard": "playwright test -c playwright.a11y.config.ts --grep @keyboard --reporter=list",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,json,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,yml,md}\"",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run format:check",
    "coverage:sync": "ts-node scripts/sync-coverage.ts",
    "coverage:check": "ts-node scripts/sync-coverage.ts --check",
    "e2e:timing:generate": "ts-node scripts/generate-e2e-timing-report.ts",
    "test:e2e:timing": "ts-node scripts/generate-e2e-timing-report.ts --run",
    "test:full:timing": "ts-node scripts/run-full-suite-with-timing.ts",
    "full-suite:timing:generate": "ts-node scripts/generate-full-suite-timing-report.ts",
    "allure:generate": "allure generate --clean ./allure-results -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "allure:serve": "allure serve ./allure-results",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "**/*.{json,yml,md}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@faker-js/faker": "^10.0.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.19.17",
    "@types/proxymise": "^1.0.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "allure-playwright": "^3.4.1",
    "cpf-cnpj-validator": "^1.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "playwright-zephyr": "^1.2.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "esutils": "^2.0.3",
    "proxymise": "^1.0.2",
    "zod": "^4.3.6"
  }
}
