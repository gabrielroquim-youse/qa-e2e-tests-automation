{
  "name": "playwright-e2e-tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/spec/e2e/journeys tests/spec/e2e/ux --grep @smoke --project=chromium",
    "test:journey": "playwright test tests/spec/e2e/journeys --grep @journey --project=chromium",
    "test:ux": "playwright test tests/spec/e2e/ux --grep @ux --project=chromium --workers=1",
    "test:regression": "playwright test tests/spec/e2e/regression --grep @regression --project=chromium",
    "test:api": "playwright test tests/spec/api --project=chromium",
    "test:api:quotation": "playwright test tests/spec/api/quotation --grep @pricing --project=chromium",
    "test:a11y": "playwright test -c playwright.a11y.config.ts --grep @a11y",
    "test:a11y:sandbox": "playwright test -c playwright.a11y.config.ts --grep @a11y",
    "test:a11y:desktop": "playwright test -c playwright.a11y.config.ts --grep @a11y --project=desktop",
    "test:a11y:tablet": "playwright test -c playwright.a11y.config.ts --grep @a11y --project=tablet",
    "test:a11y:mobile": "playwright test -c playwright.a11y.config.ts --grep @a11y --project=mobile-chrome --project=mobile-ios",
    "test:keyboard": "playwright test -c playwright.a11y.config.ts --grep @keyboard",
    "test:keyboard:desktop": "playwright test -c playwright.a11y.config.ts --grep @keyboard --project=desktop",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,json,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,yml,md}\"",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run format:check",
    "coverage:sync": "ts-node scripts/sync-coverage.ts",
    "coverage:check": "ts-node scripts/sync-coverage.ts --check",
    "test:ux:timing": "ts-node scripts/generate-e2e-timing-report.ts --run-ux",
    "e2e:timing:generate": "ts-node scripts/generate-e2e-timing-report.ts",
    "test:e2e:timing": "ts-node scripts/generate-e2e-timing-report.ts --run",
    "test:full:timing": "ts-node scripts/run-full-suite-with-timing.ts",
    "full-suite:timing:generate": "ts-node scripts/generate-full-suite-timing-report.ts",
    "allure:environment": "ts-node scripts/allure-environment.ts",
    "allure:history:restore": "node -e \"const{cpSync,existsSync,mkdirSync}=require('fs'),s='reports/allure-history',d='allure-results/history';if(existsSync(s)){mkdirSync(d,{recursive:true});cpSync(s,d,{recursive:true});console.log('[allure] Histórico restaurado →',d);}else{console.log('[allure] Sem histórico salvo ainda.');}\"",
    "allure:history:save": "node -e \"const{cpSync,existsSync,mkdirSync}=require('fs'),s='allure-report/history',d='reports/allure-history';if(existsSync(s)){mkdirSync(d,{recursive:true});cpSync(s,d,{recursive:true});console.log('[allure] Histórico salvo →',d);}else{console.log('[allure] Sem allure-report/history para salvar.');}\"",
    "allure:generate": "npm run allure:environment && npm run allure:history:restore && allure generate --clean ./allure-results -o ./allure-report && npm run allure:history:save",
    "allure:open": "allure open ./allure-report",
    "allure:serve": "npm run allure:environment && npm run allure:history:restore && allure serve ./allure-results",
    "report:a11y": "ts-node scripts/generate-a11y-report.ts --format=html",
    "report:a11y:json": "ts-node scripts/generate-a11y-report.ts --format=json",
    "report:a11y:md": "ts-node scripts/generate-a11y-report.ts --format=markdown",
    "report:a11y:all": "npm run report:a11y && npm run report:a11y:json && npm run report:a11y:md && npm run report:a11y && open ./reports/a11y-report-$(date +%Y-%m-%d).html",
    "test:payment": "playwright test tests/spec/e2e/payment --project=chromium --workers=1",
    "test:pix:emission": "cross-env PIX_SANDBOX_EMISSION=1 playwright test tests/spec/e2e/payment/checkout-pix-emission.spec.ts --project=chromium --headed",
    "test:pix:record": "cross-env PIX_RECORD=1 PIX_SANDBOX_EMISSION=1 PIX_SANDBOX_AUTO_PAY=1 PIX_SANDBOX_MANUAL_PAUSE=0 PW_VIDEO=on PW_SLOW_MO=60 playwright test tests/spec/e2e/payment/checkout-pix-record.spec.ts --project=chromium --headed --workers=1",
    "test:pix:record:ui": "cross-env PW_VIDEO=on PW_SLOW_MO=40 playwright test tests/spec/e2e/payment/checkout-pix.spec.ts -g PAY-P4 --project=chromium --headed --workers=1",
    "test:pix:record:export": "npm run test:pix:record && npm run tool:pix-video:export",
    "test:pix:record:ui:export": "npm run test:pix:record:ui && npm run tool:pix-video:export",
    "tool:pix-capture": "playwright test tests/spec/tools/pix-brcode-capture.spec.ts --project=chromium --reporter=list",
    "tool:pix-confirm": "ts-node scripts/pix-sandbox-confirm.ts",
    "tool:pix-pay": "ts-node scripts/pix-sandbox-pay.ts",
    "tool:pix-video:export": "ts-node scripts/export-pix-video.ts",
    "qa:status": "ts-node scripts/qa-status.ts",
    "qa:precommit": "ts-node --transpile-only scripts/qa-pre-commit-checks.ts",
    "qa:commitmsg": "ts-node --transpile-only scripts/qa-commit-msg.ts",
    "qa:check": "npm run validate && npm run qa:precommit",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "**/*.{json,yml,md}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@datadog/datadog-ci": "^5.20.1",
    "@faker-js/faker": "^10.0.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.19.17",
    "@types/proxymise": "^1.0.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "allure-playwright": "^3.4.1",
    "cpf-cnpj-validator": "^1.0.3",
    "cross-env": "^10.1.0",
    "dd-trace": "^5.110.0",
    "dotenv": "^17.2.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "playwright-zephyr": "^1.2.0",
    "prettier": "^3.6.2",
    "starkbank": "^2.40.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "esutils": "^2.0.3",
    "proxymise": "^1.0.2",
    "zod": "^4.3.6"
  }
}
